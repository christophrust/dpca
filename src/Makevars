PKG_CFLAGS = -I"arpack" -DUSING_R

UNAME := $(shell uname -s)

ifeq ($(UNAME), Darwin)
  PKG_LIBS = arpack/libarpack.a $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) -Wl,-exported_symbols_list,dpca.exp
else
  # Linux and other ELF platforms
  PKG_LIBS = arpack/libarpack.a $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) -Wl,--verbose,--version-script=dpca.map
endif

$(SHLIB): arpack/libarpack.a

arpack/libarpack.a:
	@(cd arpack && $(MAKE) libarpack.a \
		FC="$(FC)" FFLAGS="$(FFLAGS) $(FPICFLAGS)" AR="$(AR)")
